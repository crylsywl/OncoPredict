{
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.5.1"
    }
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/predict",
      "destination": "/api/predict"
    },
    {
      "source": "/api/predict_csv",
      "destination": "/api/predict_csv"
    }
  ]
}
